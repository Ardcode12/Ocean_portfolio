/* ===== SKILLS SECTION — OCEAN ORB GRID ===== */

/* Depth Tabs */
.depth-tabs {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 50px;
    flex-wrap: wrap;
}

.depth-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    border-radius: 50px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.35s ease;
    letter-spacing: 0.5px;
}

.depth-tab:hover {
    border-color: var(--ocean-glow);
    color: var(--ocean-glow);
    background: rgba(0, 229, 255, 0.08);
}

.depth-tab.active {
    background: linear-gradient(135deg, rgba(0, 229, 255, 0.15), rgba(0, 255, 200, 0.1));
    border-color: var(--ocean-glow);
    color: var(--ocean-glow);
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.15);
}

.tab-icon {
    font-size: 1rem;
}

/* Skills Ocean Grid */
.skills-ocean-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 30px;
    max-width: 1000px;
    margin: 0 auto;
    justify-items: center;
}

/* Individual Skill Orb */
.skill-orb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: scale(0.7) translateY(20px);
}

.skill-orb.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
}

.skill-orb.filtered-out {
    opacity: 0 !important;
    transform: scale(0.5) !important;
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
}

.skill-orb:hover {
    transform: scale(1.1) translateY(-5px);
}

.orb-ring {
    position: relative;
    width: 110px;
    height: 110px;
}

.orb-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.orb-track {
    fill: none;
    stroke: rgba(0, 229, 255, 0.08);
    stroke-width: 4;
}

.orb-fill {
    fill: none;
    stroke: url(#orb-gradient);
    stroke: var(--ocean-glow);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-dasharray: 326.73;
    stroke-dashoffset: calc(326.73 - (326.73 * var(--pct) / 100));
    transition: stroke-dashoffset 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 0 6px rgba(0, 229, 255, 0.4));
}

.orb-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
}

.orb-icon {
    font-size: 1.6rem;
    transition: transform 0.3s ease;
}

.skill-orb:hover .orb-icon {
    transform: scale(1.2);
}

.orb-value {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--ocean-glow);
}

.orb-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-align: center;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
