import { useEffect, useRef } from 'react';
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

/**
 * Renders the octo.glb model inside a small canvas
 * that sits in the center gap of the skills circle.
 */
function OctoModel() {
    const containerRef = useRef(null);

    useEffect(() => {
        const container = containerRef.current;
        if (!container) return;

        const width = 260;
        const height = 260;

        // Scene
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(40, width / height, 0.1, 100);
        camera.position.set(0, 0.3, 3.5);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setClearColor(0x000000, 0);
        renderer.setSize(width, height);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        // Lights
        scene.add(new THREE.AmbientLight(0x88ccff, 2.5));
        const key = new THREE.DirectionalLight(0xffffff, 2.0);
        key.position.set(3, 5, 5);
        scene.add(key);
        const fill = new THREE.DirectionalLight(0x66aacc, 1.2);
        fill.position.set(-3, 2, 4);
        scene.add(fill);
        const rim = new THREE.DirectionalLight(0x00e5ff, 0.8);
        rim.position.set(0, -2, -3);
        scene.add(rim);

        // State
        let mixer = null;
        const clock = new THREE.Clock();
        let animFrameId;
        let model = null;

        // Load octo
        const loader = new GLTFLoader();
        loader.load(
            '/glb_files/octo.glb',
            (gltf) => {
                model = gltf.scene;

                // Auto-fit to view
                const box = new THREE.Box3().setFromObject(model);
                const size = box.getSize(new THREE.Vector3());
                const center = box.getCenter(new THREE.Vector3());
                const maxDim = Math.max(size.x, size.y, size.z);
                const scale = 2.8 / maxDim;
                model.scale.setScalar(scale);
                model.position.set(
                    -center.x * scale,
                    -center.y * scale + 0.1,
                    -center.z * scale
                );

                // Face front
                model.rotation.y = Math.PI;

                // Enhance materials for underwater look
                model.traverse((child) => {
                    if (child.isMesh && child.material) {
                        child.material.envMapIntensity = 1.5;
                        if (child.material.emissive) {
                            child.material.emissive.set(0x224466);
                            child.material.emissiveIntensity = 0.15;
                        }
                        child.material.needsUpdate = true;
                    }
                });

                scene.add(model);

                // Play first animation if available
                if (gltf.animations && gltf.animations.length > 0) {
                    mixer = new THREE.AnimationMixer(model);
                    const action = mixer.clipAction(gltf.animations[0]);
                    action.play();
                }

                console.log('🐙 Octo model loaded in skills center');
            },
            undefined,
            (err) => console.error('❌ Octo load error:', err)
        );

        // Animate
        function animate() {
            animFrameId = requestAnimationFrame(animate);
            const delta = clock.getDelta();

            if (mixer) mixer.update(delta);

            // Keep front-facing (no rotation)

            renderer.render(scene, camera);
        }
        animate();

        // Cleanup
        return () => {
            cancelAnimationFrame(animFrameId);
            renderer.dispose();
            if (container.contains(renderer.domElement)) {
                container.removeChild(renderer.domElement);
            }
        };
    }, []);

    return (
        <div
            ref={containerRef}
            className="octo-model-container"
        />
    );
}

export default OctoModel;

