                            >
                                {/* ★ Center gap — placeholder for a future 3D model */}
                                <div className="circle-center-gap" id="skills-center-model">
                                    <div className="center-ring-outer" />
                                    <div className="center-ring-mid" />
                                    <div className="center-ring-inner" />
                                    <div className="center-content">
                                        <OctoModel />
                                    </div>
                                </div>

                                {/* ★ Decorative orbit ring */}
                                <div
                                    className="orbit-ring"
                                    style={{
                                        width: `${CIRCLE_RADIUS * 2}px`,
                                        height: `${CIRCLE_RADIUS * 2}px`,
                                    }}
                                />

                                {/* ★ Skill orbs arranged in a circle */}
                                {filteredSkills.map((s, i) => {
                                    const angleRad =
                                        ((360 / filteredSkills.length) * i - 90) *
                                        (Math.PI / 180);
                                    const x = Math.cos(angleRad) * CIRCLE_RADIUS;
                                    const y = Math.sin(angleRad) * CIRCLE_RADIUS;

                                    return (
                                        <div
                                            key={s.skill}
                                            className="skill-orb-positioned"
                                            style={{
                                                left: `calc(50% + ${x}px)`,
                                                top: `calc(50% + ${y}px)`,
                                                transitionDelay: `${i * 0.04}s`,
                                            }}
                                            data-category={s.category}
                                        >
                                            <div className="orb-ring">
                                                <svg viewBox="0 0 120 120">
                                                    <circle
                                                        cx="60"
                                                        cy="60"
                                                        r="52"
                                                        className="orb-track"
                                                    />
                                                    <circle
                                                        cx="60"
                                                        cy="60"
                                                        r="52"
                                                        className="orb-fill"
                                                        style={{ '--pct': s.pct }}
                                                    />
                                                </svg>
                                                <div className="orb-center">
                                                    <span className="orb-icon">{s.icon}</span>
                                                    <span className="orb-value">{s.pct}%</span>
                                                </div>
                                            </div>
                                            <span className="orb-label">{s.skill}</span>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </div>

                    {/* RIGHT — Fish area (3D canvas renders through here) */}
                    <div className="skills-fish-side" />
                </div>
            </div>
        </section>
    );
}

