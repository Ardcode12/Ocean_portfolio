/* ===== SKILLS SECTION — CIRCULAR LAYOUT ===== */

/* ── Split layout: circle left, fish right ── */
.skills-layout {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 10px;
}

.skills-circle-side {
    flex: 0 0 58%;
    display: flex;
    justify-content: center;
    align-items: center;
}

.skills-fish-side {
    flex: 1;
    min-height: 450px;
    /* Fish renders here via the fixed 3D canvas */
}

/* ── Circle wrapper ── */
.skills-circle-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
}

.skills-circle {
    position: relative;
    /* width & height set inline via JS */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* ── Decorative orbit ring ── */
.orbit-ring {
    position: absolute;
    /* width & height set inline via JS */
    border-radius: 50%;
    border: 1px solid rgba(0, 229, 255, 0.06);
    pointer-events: none;
    animation: orbitSpin 60s linear infinite;
}

.orbit-ring::before {
    content: '';
    position: absolute;
    top: -2px;
    left: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--ocean-glow);
    box-shadow: 0 0 8px var(--ocean-glow);
    transform: translateX(-50%);
}

@keyframes orbitSpin {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

/* ── Center gap for future 3D model ── */
.circle-center-gap {
    position: absolute;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
}

.center-ring-outer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px dashed rgba(0, 229, 255, 0.15);
    animation: centerRotate 20s linear infinite;
}

.center-ring-mid {
    position: absolute;
    inset: 12px;
    border-radius: 50%;
    border: 1px solid rgba(0, 229, 255, 0.08);
