import { useEffect } from 'react';
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

export default function useScrollAnimations(loading) {
    useEffect(() => {
        if (loading) return;

        // Wait a frame so the DOM is ready
        const raf = requestAnimationFrame(() => {
            setupHeroAnimation();
            setupSectionAnimations();
        });

        return () => {
            cancelAnimationFrame(raf);
            // Kill only the scroll-animation triggers we created, not the fish ones
        };
    }, [loading]);
}

function setupHeroAnimation() {
    const tl = gsap.timeline({ delay: 0.5 });
    tl.to('.hero-badge', { opacity: 1, y: 0, duration: 0.6 });
    tl.to('.line-1', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3');
    tl.to('.line-2', { opacity: 1, y: 0, duration: 0.7 }, '-=0.3');
    tl.to('.line-3', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3');
    tl.to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.5 }, '-=0.2');
    tl.to('.hero-cta', { opacity: 1, y: 0, duration: 0.5 }, '-=0.2');
    tl.to('.scroll-indicator', { opacity: 0.7, duration: 0.8 }, '-=0.2');
}

function setupSectionAnimations() {
    ['about', 'skills', 'projects', 'contact'].forEach((id) => {
        const section = document.getElementById(id);
        if (!section) return;

        const label = section.querySelector('.section-label');
        const title = section.querySelector('.section-title');

        gsap
            .timeline({
                scrollTrigger: {
                    trigger: section,
                    start: 'top 70%',
                    toggleActions: 'play none none reverse',
                },
            })
            .to(label, { opacity: 1, x: 0, duration: 0.5 }, 0)
            .to(title, { opacity: 1, x: 0, duration: 0.6 }, 0.1);

        if (id === 'about') {
            gsap.to('.about-card', {
                opacity: 1,
                y: 0,
                duration: 0.6,
                scrollTrigger: { trigger: section, start: 'top 60%' },
            });
            gsap.to('.stats-row', {
                opacity: 1,
                y: 0,
                duration: 0.6,
                scrollTrigger: { trigger: section, start: 'top 50%' },
            });
            ScrollTrigger.create({
                trigger: section,
                start: 'top 55%',
                once: true,
                onEnter: () => {
                    document.querySelectorAll('.stat-number').forEach((el) => {
                        gsap.to(el, {
                            innerText: parseInt(el.dataset.count),
                            duration: 2,
                            snap: { innerText: 1 },
                            onUpdate() {
                                el.textContent = Math.round(parseFloat(el.textContent));
                            },
                        });
                    });
                },
            });
        }

        if (id === 'skills') {
            ScrollTrigger.create({
                trigger: section,
                start: 'top 60%',
                once: true,
                onEnter: () => {
                    document.querySelectorAll('.skill-orb').forEach((orb, i) => {
                        setTimeout(() => orb.classList.add('visible'), i * 80);
                    });
                },
            });
        }

        if (id === 'projects') {
            gsap.to('.bento-grid', {
                opacity: 1,
                y: 0,
                duration: 0.5,
                scrollTrigger: { trigger: section, start: 'top 70%' },
            });
            gsap.to('.bento-card', {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 0.6,
                stagger: 0.12,
                scrollTrigger: { trigger: section, start: 'top 60%' },
            });
        }

        if (id === 'contact') {
            gsap.to('.contact-card', {
                opacity: 1,
                y: 0,
                duration: 0.6,
                scrollTrigger: { trigger: section, start: 'top 60%' },
            });
            gsap.to('.social-row', {
                opacity: 1,
                y: 0,
                duration: 0.6,
                scrollTrigger: { trigger: section, start: 'top 50%' },
            });
        }
    });
}
